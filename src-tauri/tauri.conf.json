{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Recall",
  "version": "0.1.0",
  "identifier": "com.recall.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Recall",
        "width": 1480,
        "height": 940,
        "minWidth": 1080,
        "minHeight": 760,
        "transparent": true,
        "windowEffects": {
          "effects": ["micaDark"]
        },
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "./resources/python": "python"
    },
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
